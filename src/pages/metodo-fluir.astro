---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Método FLUIR+ — Gonzalo Pareja">
  <main class="relative min-h-dvh bg-black" style="background-color: #000;">
    <!-- Global background (keep consistent, avoid hard cuts) -->
    <div class="pointer-events-none fixed inset-0 z-0" aria-hidden="true">
      <div
        class="absolute inset-0"
        style="background-image: url('/intervencion-bg.jpg'); background-size: cover; background-position: center; filter: saturate(1.03) contrast(1.03);"
      ></div>
      <div class="absolute inset-0 bg-black/70"></div>
    </div>

    <div class="relative z-10">

    <!-- Hero: copy impactante + vídeo -->
    <section class="relative">
      <div class="relative z-10 mx-auto flex max-w-5xl flex-col items-center px-6 pb-10 pt-16 text-center">
        <p class="text-xs font-semibold tracking-widest text-white/60">GONZALO PAREJA (Dirección Estratégica)</p>

        <h1 class="mt-3 max-w-4xl text-balance text-4xl font-extrabold leading-tight tracking-tight sm:text-6xl">
          Estás haciendo lo que puedes. Pero no <span class="text-red-500">lo que deberías</span>.
          Y eso <span class="text-red-500">tiene consecuencias</span>
        </h1>

        <p class="mt-6 max-w-3xl text-pretty text-base text-white/80 sm:text-lg">
          Si estás en un momento importante y
          <span class="underline decoration-white/80 decoration-1 underline-offset-4">no quieres volver a equivocarte</span>,
          empieza aquí.
        </p>

        <div class="mt-10 w-full max-w-4xl">
          <div class="relative aspect-video overflow-hidden rounded-md bg-black" style="contain: paint; isolation: isolate; transform: translateZ(0);">
            <video
              id="metodoFluirVideo"
              class="absolute block bg-black object-cover"
              style="
                /* Overscan without scaling (reduces Chrome edge shimmer/jitter) */
                top: -2px;
                left: -2px;
                width: calc(100% + 4px);
                height: calc(100% + 4px);

                transform: translate3d(0,0,0);
                backface-visibility: hidden;
                will-change: transform;
              "
              src="/metodo-fluir.mp4"
              autoplay
              playsinline
              controls
              preload="metadata"
            ></video>

            <!-- Overlay shown when video ends -->
            <div
              id="videoEndOverlay"
              class="pointer-events-auto absolute inset-0 hidden items-center justify-center bg-black/70 px-6 py-6 text-center"
            >
              <div class="max-w-3xl">
                <p class="text-balance text-2xl font-extrabold leading-snug tracking-tight sm:text-5xl">
                  No es suerte. Es el resultado de decisiones sostenidas.
                  Si quieres otro resultado, tendrás que empezar a <span class="text-red-500">decidir distinto</span>.
                </p>
                <button
                  type="button"
                  id="ignoreOverlayBtn"
                  class="mt-8 text-[10px] font-semibold tracking-widest text-white/70 underline decoration-white/60 underline-offset-4 hover:text-white"
                >
                  <span class="underline decoration-white/60 underline-offset-4">La pregunta es si tú estás dispuesto.</span>
                </button>
              </div>
            </div>
          </div>
        </div>

        <div class="mt-10 flex w-full flex-col items-center gap-4">
          <a href="/checkout" class="inline-flex h-12 w-full max-w-md items-center justify-center bg-red-600 px-8 text-sm font-semibold">
            👉 Solicitar sesión 1:1 (60€)
          </a>
        </div>
      </div>
    </section>

    <!-- INTERVENCIÓN ESTRATÉGICA 60D (high-ticket visual) -->
    <section class="relative px-6 pt-10 pb-20 sm:pt-14 sm:pb-28">
      <div class="relative z-10 mx-auto max-w-6xl">
        <!-- HERO CARD -->
        <div class="mx-auto max-w-4xl rounded-2xl bg-black/55 p-10 text-center shadow-2xl ring-1 ring-white/10 backdrop-blur sm:p-14">
          <p class="text-xs font-semibold tracking-widest text-white/70">GONZALO PAREJA · DIRECCIÓN ESTRATÉGICA</p>
          <h2 class="mt-6 text-balance text-4xl font-extrabold leading-tight tracking-tight text-white sm:text-6xl">
            Intervención Estratégica 60D
          </h2>
          <p class="mt-6 text-pretty text-base text-white/80 sm:text-lg">
            Si estás en un momento importante y no quieres volver a equivocarte, trabajamos eso.
          </p>
          <a
            href="/checkout"
            class="mt-10 inline-flex h-12 items-center justify-center rounded bg-red-600 px-10 text-sm font-semibold text-white sm:h-14 sm:px-14 sm:text-base"
          >
            Solicitar sesión 1:1 (60€)
          </a>
        </div>

        <!-- CARDS STACK (background visible around cards) -->
        <div class="mx-auto mt-14 grid max-w-5xl gap-8">
          <!-- Problema real -->
          <div class="rounded-2xl bg-white/95 p-10 text-center shadow-2xl ring-1 ring-black/5 sm:p-14">
            <h3 class="text-balance text-3xl font-extrabold tracking-tight text-black sm:text-5xl">Tu problema no es de falta de información</h3>
            <p class="mt-8 text-balance text-lg text-black/75 sm:text-2xl">
              Es cómo estás decidiendo.<br />
              Mientras eso no cambie, todo se repite.
            </p>
          </div>

          <!-- Qué es / qué no es -->
          <div class="rounded-2xl bg-black/55 p-10 shadow-2xl ring-1 ring-white/10 backdrop-blur sm:p-14">
            <div class="mx-auto grid max-w-4xl gap-10 sm:grid-cols-2">
              <div class="mx-auto max-w-md">
                <p class="text-xs font-semibold tracking-widest text-white/60">QUÉ ES</p>
                <p class="mt-5 text-xl font-semibold text-white sm:text-2xl">Intervención directa. Trabajo 1:1. Decisiones reales.</p>
                <p class="mt-4 text-base leading-relaxed text-white/75">
                  60 días de enfoque absoluto. Sin teoría innecesaria. Sin perder el tiempo.
                </p>
              </div>
              <div class="mx-auto max-w-md">
                <p class="text-xs font-semibold tracking-widest text-white/60">QUÉ NO ES</p>
                <p class="mt-5 text-base leading-relaxed text-white/75">
                  No es un curso. No es un grupo. No es mentoría motivacional. No es inspiración semanal.
                  <span class="font-semibold text-white">Es trabajo serio.</span>
                </p>
              </div>
            </div>
          </div>

          <!-- Qué hacemos -->
          <div class="rounded-2xl bg-white/95 p-10 text-center shadow-2xl ring-1 ring-black/5 sm:p-14">
            <h3 class="text-3xl font-extrabold tracking-tight text-black sm:text-5xl">Qué trabajamos en 60 días</h3>
            <ul class="mx-auto mt-10 grid max-w-3xl gap-4 text-left text-base text-black/75 sm:text-center">
              <li>– Analizamos tu situación sin autoengaños.</li>
              <li>– Definimos juntos tus objetivos.</li>
              <li>– Detectamos patrones que te frenan.</li>
              <li>– Reordenamos prioridades.</li>
              <li>– Elevamos estándar.</li>
              <li>– Definimos decisiones ejecutables.</li>
            </ul>
            <p class="mt-10 text-sm font-semibold tracking-wide text-black/60">Sin teoría vacía. Trabajo directo.</p>
          </div>

          <!-- Cómo funciona -->
          <div class="rounded-2xl bg-black/55 p-10 text-center shadow-2xl ring-1 ring-white/10 backdrop-blur sm:p-14">
            <h3 class="text-center text-3xl font-extrabold tracking-tight text-white sm:text-5xl">Cómo funciona</h3>
            <div class="mx-auto mt-12 grid max-w-4xl gap-10 sm:grid-cols-3">
              <div class="mx-auto max-w-xs">
                <p class="text-6xl font-black tracking-tight text-white/90">01</p>
                <p class="mt-4 text-base text-white/75">Sesión de diagnóstico 1:1 (60€).</p>
              </div>
              <div class="mx-auto max-w-xs">
                <p class="text-6xl font-black tracking-tight text-white/90">02</p>
                <p class="mt-4 text-base text-white/75">Si encajas <span class="underline underline-offset-4 decoration-white/80 decoration-1">y estás preparado</span>, se desbloquea el programa.</p>
              </div>
              <div class="mx-auto max-w-xs">
                <p class="text-6xl font-black tracking-tight text-white/90">03</p>
                <p class="mt-4 text-base text-white/75">60 días de intervención intensiva.</p>
              </div>
            </div>
            <p class="mt-12 text-center text-sm text-white/60">El acceso es muy selectivo. Eso marca la diferencia.</p>
          </div>

          <!-- Para quién es -->
          <div class="rounded-2xl bg-white/95 p-10 shadow-2xl ring-1 ring-black/5 sm:p-14">
            <div class="mx-auto grid max-w-4xl gap-10 sm:grid-cols-2">
              <div class="text-center">
                <h3 class="text-2xl font-extrabold tracking-tight text-black sm:text-3xl">Para quién es</h3>
                <ul class="mt-6 space-y-3 text-left text-base text-black/75 sm:text-center">
                  <li>– Está ante una decisión importante.</li>
                  <li>– Sabe que puede estar mucho mejor.</li>
                  <li>– Está cansado de repetir patrones.</li>
                  <li>– Quiere resultados, punto.</li>
                </ul>
              </div>
              <div class="text-center">
                <h3 class="text-2xl font-extrabold tracking-tight text-black sm:text-3xl">Para quién no es</h3>
                <ul class="mt-6 space-y-3 text-left text-base text-black/75 sm:text-center">
                  <li>– Busca motivación.</li>
                  <li>– Quiere que le digan lo que quiere oír.</li>
                  <li>– No está dispuesto a asumir responsabilidad total.</li>
                  <li>– No quiere dejarse ayudar</li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Inversión -->
          <div class="rounded-2xl bg-black/55 p-10 text-center shadow-2xl ring-1 ring-white/10 backdrop-blur sm:p-14">
            <p class="text-xs font-semibold tracking-widest text-white/60">INVERSIÓN a partir de</p>
            <p class="mt-6 text-5xl font-extrabold tracking-tight text-white sm:text-7xl">2.400€ + IVA</p>
            <a
              href="/checkout"
              class="mt-10 inline-flex h-12 items-center justify-center rounded bg-red-600 px-10 text-sm font-semibold text-white sm:h-14 sm:px-14 sm:text-base"
            >
              Solicitar sesión 1:1 (60€)
            </a>
          </div>
        </div>
      </div>
    </section>

    </div>

    <!-- Footer (Kajabi-like) -->
    <footer class="relative z-10 mt-12 bg-[#2f343a] px-6 py-10 text-white">
      <div class="mx-auto max-w-5xl text-center">
        <p class="text-sm font-semibold text-white/95">© {new Date().getFullYear()} Gonzalo Pareja Bolaños</p>

        <div class="mt-6 flex items-center justify-center gap-8">
          <a href="https://www.instagram.com/gonzalo.pareja.ig/" target="_blank" rel="noopener noreferrer" class="text-white/95 hover:text-white" aria-label="Instagram">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M7 2h10a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5V7a5 5 0 0 1 5-5Z" stroke="currentColor" stroke-width="1.8"/>
              <path d="M12 17a5 5 0 1 0 0-10 5 5 0 0 0 0 10Z" stroke="currentColor" stroke-width="1.8"/>
              <path d="M17.5 6.5h.01" stroke="currentColor" stroke-width="3.4" stroke-linecap="round"/>
            </svg>
          </a>
          <a href="https://www.youtube.com/@GonzaloParejaBola%C3%B1os" target="_blank" rel="noopener noreferrer" class="text-white/95 hover:text-white" aria-label="YouTube">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M21.7 8.1a3 3 0 0 0-2.1-2.1C17.8 5.5 12 5.5 12 5.5s-5.8 0-7.6.5A3 3 0 0 0 2.3 8.1 31 31 0 0 0 2 12a31 31 0 0 0 .3 3.9 3 3 0 0 0 2.1 2.1c1.8.5 7.6.5 7.6.5s5.8 0 7.6-.5a3 3 0 0 0 2.1-2.1A31 31 0 0 0 22 12a31 31 0 0 0-.3-3.9Z" stroke="currentColor" stroke-width="1.8"/>
              <path d="M10 9.5v5l5-2.5-5-2.5Z" fill="currentColor"/>
            </svg>
          </a>
          <a href="https://www.linkedin.com/in/gonzalo-pareja-bola%C3%B1os/" target="_blank" rel="noopener noreferrer" class="text-white/95 hover:text-white" aria-label="LinkedIn">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M6.5 9.5V18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
              <path d="M6.5 6.8h0" stroke="currentColor" stroke-width="3.4" stroke-linecap="round"/>
              <path d="M10 18v-5.2c0-1.8 1-3 2.7-3 1.6 0 2.3 1 2.3 3V18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
              <path d="M10 9.5V18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
              <path d="M3.5 2h17a3 3 0 0 1 3 3v14a3 3 0 0 1-3 3h-17a3 3 0 0 1-3-3V5a3 3 0 0 1 3-3Z" stroke="currentColor" stroke-width="1.3"/>
            </svg>
          </a>
        </div>
      </div>
    </footer>

    <script is:inline>
      const v = document.getElementById('metodoFluirVideo');
      const overlay = document.getElementById('videoEndOverlay');
      const ignoreBtn = document.getElementById('ignoreOverlayBtn');

      if (v && overlay) {
        v.addEventListener('ended', () => {
          overlay.classList.remove('hidden');
          overlay.classList.add('flex');
        });
      }

      if (ignoreBtn && overlay) {
        ignoreBtn.addEventListener('click', () => {
          overlay.classList.add('hidden');
          overlay.classList.remove('flex');
        });
      }
    </script>
  </main>
</BaseLayout>
