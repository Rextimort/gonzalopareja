---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Deja de depender de un salario — Programa de Intervención 60D">
  <main class="min-h-dvh bg-black">
    <section class="relative min-h-[55vh]">
      <div class="absolute inset-0 bg-neutral-900"></div>
      <div class="absolute inset-0 bg-black/55"></div>
      <div class="relative z-10 mx-auto flex max-w-5xl flex-col items-center px-6 py-16 text-center">
        <h1 class="text-3xl font-extrabold tracking-tight sm:text-4xl">Esta es la puerta.</h1>
        <p class="mt-4 max-w-2xl text-sm text-white/75">
          (Placeholder) Mantendremos el look&feel actual de “Salas”, pero con un único producto.
        </p>
        <a href="/login" class="mt-10 inline-flex h-12 items-center justify-center bg-red-600 px-8 text-sm font-semibold">YA SOY ALUMNO</a>
      </div>
    </section>

    <section class="mx-auto max-w-5xl px-6 py-14">
      <div class="rounded-md bg-neutral-950/70 p-8 text-center ring-1 ring-white/10">
        <h2 class="text-2xl font-bold">CAMBIA TU REALIDAD — APRENDE A FLUIR+</h2>
        <p class="mt-4 text-sm text-white/70">
          (Placeholder) Producto único. Precio 400€.
        </p>
        <a href="/checkout" class="mt-8 inline-flex h-12 items-center justify-center bg-red-600 px-8 text-sm font-semibold">Quiero empezar</a>
      </div>
    </section>
  </main>
</BaseLayout>
